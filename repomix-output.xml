/* ====================================
   LAYOUT & WORKSPACE
   ==================================== */

/* Workspace Layout */
.workspace {
    display: flex;
    height: calc(100vh - 65px);
}

.pane {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border);
    position: relative;
    overflow: hidden;
}

.resize-divider {
    width: 6px;
