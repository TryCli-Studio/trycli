) -> impl IntoView {
    view! {
        {move || match error.get() {
            Some(err) => view! {
                <div class="error-state">
                    <p class="error-message">{err}</p>
                    <button class="btn-primary" on:click=move |_| {
                        set_error.set(None);
                        set_loading.set(true);
